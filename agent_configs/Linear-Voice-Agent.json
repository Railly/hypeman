                            "dynamicVariablePlaceholders": {
                                "user_id": "user_2xtggkO3dW6oM8owNPy7EMof7dk",
                                "teams": "[{\"id\":\"b55bef56-c675-4a16-bd61-1a8f28c7a386\",\"displayName\":\"GitHunter\"},{\"id\":\"884da8b6-75b9-4fc5-81b4-13be296ec212\",\"displayName\":\"Crafter UI\"},{\"id\":\"853ccaea-da05-43ca-8727-2f8c22e04253\",\"displayName\":\"Fom0\"},{\"id\":\"1c2c9dd6-5fab-4c9b-8775-827fa789e560\",\"displayName\":\"Tinte\"},{\"id\":\"7c5f6895-53b9-4144-adca-b3e7e1970600\",\"displayName\":\"Gradual\"},{\"id\":\"5f7253eb-1524-4c04-935b-f5cff1082cb9\",\"displayName\":\"Agile Monkeys\"}]"
